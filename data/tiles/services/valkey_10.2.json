{
  "name": "Tanzu for Valkey on Tanzu Platform",
  "version": "10.2.x",
  "supportedIaaS": ["vsphere", "aws", "azure", "gcp", "openstack"],
  "supportedRuntimeKeys": ["ert_6.0", "ert_10.2", "ert_10.3", "ert_10.3_small_footprint"],
  "sizes": [
    {
      "size": "all",
      "displayName": "All"
    }
  ],
  "jobs":
  [
    {
      "vm": "Valkey On-Demand Broker",
      "dynamicIPs": 1,
      "staticIPs": 0,
      "singleton": true,
      "defaults": {
        "all": {
          "instances": 1
        }
      },
      "iaas": {
        "vsphere": {
          "all": {
            "instanceType": "medium",
            "validInstanceTypes": [
              "medium"
            ]
          }
        },
        "aws": {
          "all": {
            "instanceType": "m5.large",
            "validInstanceTypes": [
              "m5.large"
            ]
          }
        },
        "azure": {
          "all": {
            "instanceType": "Standard_B2s",
            "validInstanceTypes": [
              "Standard_B2s"
            ]
          }
        },
        "gcp": {
          "all": {
            "instanceType": "medium",
            "validInstanceTypes": [
              "medium"
            ]
          }
        },
        "openstack": {
          "all": {
            "instanceType": "m1.medium",
            "validInstanceTypes": [
              "m1.medium"
            ]
          }
        }
      }
    },
    {
      "vm": "Redis Broker",
      "dynamicIPs": 1,
      "staticIPs": 0,
      "singleton": false,
      "defaults": {
        "all": {
          "instances": 1,
          "persistentDisk": 10
        }
      },
      "iaas": {
        "vsphere": {
          "all": {
            "instanceType": "medium",
            "validInstanceTypes": [
              "medium"
            ]
          }
        },
        "aws": {
          "all": {
            "instanceType": "m5.large",
            "validInstanceTypes": [
              "m5.large"
            ]
          }
        },
        "azure": {
          "all": {
            "instanceType": "Standard_B2s",
            "validInstanceTypes": [
              "Standard_B2s"
            ]
          }
        },
        "gcp": {
          "all": {
            "instanceType": "medium",
            "validInstanceTypes": [
              "medium"
            ]
          }
        },
        "openstack": {
          "all": {
            "instanceType": "m1.medium",
            "validInstanceTypes": [
              "m1.medium"
            ]
          }
        }
      }
    }
  ]
}
