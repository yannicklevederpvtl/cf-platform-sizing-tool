{
  "name": "Tanzu RabbitMQ on Tanzu Platform",
  "version": "10.1.x",
  "supportedIaaS": ["vsphere", "aws", "azure", "gcp", "openstack"],
  "supportedRuntimeKeys": ["ert_6.0", "ert_10.2", "ert_10.3", "ert_10.3_small_footprint"],
  "sizes": [
    { "size": "all", "displayName": "All" }
  ],
  "jobs": [
    {
      "vm": "RabbitMQ service broker",
      "dynamicIPs": 0,
      "staticIPs": 0,
      "singleton": true,
      "defaults": { "all": { "instances": 0 } },
      "iaas": {
        "vsphere": { "all": { "instanceType": "small" } },
        "aws": { "all": { "instanceType": "t3.small" } },
        "azure": { "all": { "instanceType": "Standard_B1ms" } },
        "gcp": { "all": { "instanceType": "e2-small" } },
        "openstack": { "all": { "instanceType": "m1.small" } }
      }
    },
    {
      "vm": "HAProxy for RabbitMQ",
      "dynamicIPs": 0,
      "staticIPs": 0,
      "singleton": true,
      "defaults": { "all": { "instances": 0 } },
      "iaas": {
        "vsphere": { "all": { "instanceType": "small" } },
        "aws": { "all": { "instanceType": "t3.small" } },
        "azure": { "all": { "instanceType": "Standard_B1ms" } },
        "gcp": { "all": { "instanceType": "e2-small" } },
        "openstack": { "all": { "instanceType": "m1.small" } }
      }
    },
    {
      "vm": "RabbitMQ node",
      "dynamicIPs": 0,
      "staticIPs": 0,
      "singleton": true,
      "defaults": { "all": { "instances": 0, "persistentDisk": 30 } },
      "iaas": {
        "vsphere": { "all": { "instanceType": "large" } },
        "aws": { "all": { "instanceType": "r5.large" } },
        "azure": { "all": { "instanceType": "Standard_D2s_v3" } },
        "gcp": { "all": { "instanceType": "e2-standard-2" } },
        "openstack": { "all": { "instanceType": "m1.medium" } }
      }
    },
    {
      "vm": "RabbitMQ on-demand broker",
      "dynamicIPs": 1,
      "staticIPs": 0,
      "singleton": true,
      "defaults": { "all": { "instances": 1, "persistentDisk": 1 } },
      "iaas": {
        "vsphere": { "all": { "instanceType": "micro" } },
        "aws": { "all": { "instanceType": "t3.micro" } },
        "azure": { "all": { "instanceType": "Standard_D2s_v3" } },
        "gcp": { "all": { "instanceType": "e2-micro" } },
        "openstack": { "all": { "instanceType": "m1.small" } }
      }
    }
  ]
}
